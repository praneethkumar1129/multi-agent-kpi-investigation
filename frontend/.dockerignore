# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Dependencies (installed inside Docker)
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Local build output (Docker creates its own build)
# -----------------------------------------------------------------------------
dist/
build/

# -----------------------------------------------------------------------------
# Environment files
# Ignore local/development secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local

# IMPORTANT:
# Include the production environment file inside the Docker build
!.env.production

# -----------------------------------------------------------------------------
# IDE / OS files
# -----------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
README.md
*.md

# -----------------------------------------------------------------------------
# Docker Compose (not required inside image)
# -----------------------------------------------------------------------------
docker-compose.yml
docker-compose.yaml
docker-compose.*.yml
docker-compose.*.yaml